# Docling 评估环境
# 使用方式: podman build -t eval-docling -f Containerfile.eval-docling .
# 运行方式: podman run --rm -it -v ./data:/eval/data eval-docling
FROM python:3.12

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl libgl1 libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir docling

WORKDIR /eval
CMD ["bash"]
