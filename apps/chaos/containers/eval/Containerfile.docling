# Docling 评估环境
# 使用方式: podman build -t eval-docling -f containers/eval/Containerfile.docling .
# 运行方式: podman run --rm -it -v ./data:/eval/data eval-docling
FROM python:3.13-slim

# 系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl libgl1 libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

# 安装 uv 包管理器
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /eval

# 使用 uv 创建虚拟环境并安装 docling
RUN uv venv && \
    uv pip install --no-cache-dir docling

CMD ["bash", "-c", "source /eval/.venv/bin/activate && bash"]
