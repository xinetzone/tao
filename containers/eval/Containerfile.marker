# marker-pdf 评估环境
# 使用方式: podman build -t eval-marker -f containers/eval/Containerfile.marker .
# 运行方式: podman run --rm -it -v ./data:/eval/data eval-marker
FROM python:3.12

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl libgl1 libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir marker-pdf

WORKDIR /eval
COPY .agents/skills/pdf-to-markdown/scripts/ /eval/scripts/

CMD ["bash"]
